+    #[cfg(target_os = "linux")]
+    fn record_wayland_capture_failure(
+        monitor_id: u32,
+        capture_disabled: &Arc<AtomicBool>,
+        capture_failures: &Arc<AtomicU32>,
+        reason: &str,
+    ) {
+        let failures = capture_failures.fetch_add(1, Ordering::Relaxed) + 1;
+        if failures >= 3 {
+            if !capture_disabled.swap(true, Ordering::Relaxed) {
+                tracing::warn!(
+                    "persistent Wayland capture disabled for monitor {} after {} init failures; falling back to portal-based capture (will flash) for this session (last error: {})",
+                    monitor_id,
+                    failures,
+                    reason
+                );
+            }
+        } else {
+            tracing::debug!(
+                "persistent Wayland capture init failed for monitor {} (attempt {}/3): {}",
+                monitor_id,
+                failures,
+                reason
+            );
+        }
+    }
